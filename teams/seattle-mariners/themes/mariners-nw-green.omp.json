{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "_terminal_background": "#003333",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#C4CED4",
          "background": "#005C5C",
          "template": " \uf07c {{ .Path }} ",
          "properties": {
            "style": "full"
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#C4CED4",
          "background": "#0C2C56",
          "template": " \ue0a0 {{ .HEAD }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }} ",
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#C4CED4",
          "background": "#003D3D",
          "template": " \ue718 {{ .Full }} ",
          "properties": {
            "display_mode": "files"
          }
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#C4CED4",
          "background": "#003D3D",
          "template": " \ue235 {{ .Full }} ",
          "properties": {
            "display_mode": "files"
          }
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#005C5C",
          "template": "\u276f "
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 2
}
